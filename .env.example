# --- LLM Provider (set ONE of these) ---
# OPENAI_KEY=sk-...
# OPENROUTER_KEY=sk-or-...

# --- Model Configuration ---
# LLM_MODEL=gpt-4.1                    # Primary model for deep reading, planning, content generation
# LLM_MODEL_LIGHT=gpt-4.1-mini         # Light model for TOC detection, target selection (defaults to LLM_MODEL)
# LLM_TEMPERATURE=0.3                  # 0.0-1.0, lower = more consistent
# LLM_MAX_TOKENS=16384                 # Max output tokens per LLM call

# --- Pipeline ---
# MAX_CONCURRENT_LLM=4                # Max parallel LLM calls for chapter processing
# VISION_ENABLED=true                 # Send images to LLM for vision-based analysis (true/false)

# --- Output ---
# EMBED_IMAGES=true                    # Base64-embed images in HTML (true/false)
# DOCUMENT_TYPE=auto                   # auto, quantitative, narrative, procedural, analytical, regulatory, mixed
